# Adapter 独立部署配置。
# 使用前复制为 .env；格式必须是 KEY=VALUE，等号两侧不要加空格，值不要加引号。

# ── 部署参数 ──
ADAPTER_IMAGE=adapter-versatile-agent-java:latest
ADAPTER_CONTAINER_NAME=adapter-versatile
ADAPTER_HOST_PORT=8191
AGENT_NETWORK=agent-net
ADAPTER_NETWORK_ALIAS=adapter-versatile
RESTART_POLICY=unless-stopped

# ── Adapter 应用参数 ──
# 必填：真实 Versatile 地址模板，必须以 http:// 或 https:// 开头并保留 {conversation_id}。
# 示例：
# VERSATILE_URL=https://versatile.example.com/v1/0/agent-manager/workflows/wealth-invest/conversations/{conversation_id}
VERSATILE_URL=
VERSATILE_TIMEOUT=600s
VERSATILE_RESULT_NODE=GXZQAResponseNode
VERSATILE_AGENT_TENANT_ID=edp-tenant
