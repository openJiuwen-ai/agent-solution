# EvoAgentAdapter 部署配置
# 使用方法：复制为 .env 并按需修改
#   cp .env.example .env && vim .env
#
# 启动：./start.sh --build   （首次启动需 --build 构建镜像）
# 停止：./stop.sh

# ===== 必填：主机路径（多 Agent 策略 A：公共父目录）=====
# 所有业务 Agent 的日志父目录（挂载到容器 /data/logs，只读）。
# 每个业务 Agent 的日志放在其子目录，如 /var/log/agents/edp_agent、.../hr_agent。
# agent_adapter_config.yaml 中 per-agent log_dir 写 /data/logs/{name} 对应此处的 {name} 子目录。
HOST_LOG_ROOT=/var/log/agents

# 所有业务 Agent 的 skills 父目录（挂载到容器 /data/skills，读写）。
# 每个业务 Agent 的 skills 放在其子目录，如 /opt/agents/skills/edp_agent。
# per-agent skills_dir 写 /data/skills/{name} 对应此处的 {name} 子目录。
HOST_SKILLS_ROOT=/opt/agents/skills

# Adapter 输出数据持久化目录（挂载到容器 /app/data，读写）
# 存储 offsets、output 归档等运行时数据
HOST_OUTPUT_DIR=/opt/agent-adapter/data

# Adapter 配置文件持久化路径（挂载到容器 /app/agent_adapter_config.yaml，读写）
# 热更新（CRUD /api/v1/config/agents）写入此文件，跨容器重建不丢失
# start.sh 首次启动时若该文件不存在，会从镜像内模板自动 seed；已存在则不覆盖
# docker-compose 部署时需在 up 前手动 cp 模板到此路径（start.sh 会自动 seed，compose 不会）
HOST_CONFIG_FILE=/opt/agent-adapter/agent_adapter_config.yaml

# ===== 可选：Adapter 服务配置 =====
# 日志轮询间隔（秒）
ADAPTER_POLL_INTERVAL=60

# 首次启动读取位置：tail（只读新日志） | head（从头读历史日志）
ADAPTER_START_FROM=tail

# 输出文件清理策略
ADAPTER_OUTPUT_RETENTION_DAYS=30
ADAPTER_OUTPUT_MAX_FILES=2000
ADAPTER_OUTPUT_MAX_FILE_SIZE=20MB

# 日志等级：DEBUG | INFO | WARNING | ERROR
ADAPTER_LOG_LEVEL=INFO
