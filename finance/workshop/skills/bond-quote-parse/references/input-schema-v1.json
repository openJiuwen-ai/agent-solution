{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BondChatCorpusPackage",
  "type": "object",
  "required": ["schema_version", "messages"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "client_request_id": { "type": "string" },
    "bond_context": {
      "type": "object",
      "properties": {
        "room_name": { "type": "string" },
        "issuer": { "type": "string" },
        "tranches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tranche_name": { "type": "string" },
              "bond_code": { "type": "string" },
              "term": { "type": "string" }
            }
          }
        }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["corpus_id", "corpus_type", "speak_time", "raw_content"],
        "properties": {
          "message_id": { "type": "string" },
          "corpus_id": { "type": "integer" },
          "corpus_type": { "oneOf": [{ "enum": [1, 2] }, { "enum": ["报价", "小广告"] }] },
          "speaker_id": { "type": "string" },
          "speaker_name": { "type": "string" },
          "institution_name": { "type": "string" },
          "speak_time": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}" },
          "raw_content": { "type": "string", "minLength": 1 }
        }
      }
    },
    "parse_options": {
      "type": "object",
      "properties": {
        "model_id": { "type": "string" },
        "only_message_ids": { "type": "array", "items": { "type": "string" } },
        "parse_advertisement": { "type": "boolean" },
        "debug": { "type": "boolean" }
      }
    }
  }
}
