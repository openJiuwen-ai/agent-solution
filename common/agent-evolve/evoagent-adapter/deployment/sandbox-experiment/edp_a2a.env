# EDPAgent a2a_service env for sandbox experiment
# NOTE: API key injected at docker run via -e; do not commit real secrets.

APP_NAME=A2A Service

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SESSION_TTL=1800
REDIS_CHECKPOINTER_TTL_MINUTES=60

BOOTSTRAP_COORDINATION_ENABLED=False

RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_SECONDS=120
GLOBAL_RATE_LIMIT_MAX_REQUESTS=200
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=30

VERSATILE_ADAPTER_URL=http://localhost:8091

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8090
FASTAPI_DEBUG=False
FASTAPI_WORKERS=1

LOG_LEVEL=INFO
LOG_FILE=logs/a2a_service.log
LOG_DIR=/app/a2a_service/logs

# LLM filled at runtime via docker -e (see start_stack.ps1)
PLANNING_AGENT_MODEL_NAME=example-model
PLANNING_AGENT_MODEL_BASE_URL=https://api.example-llm.com/v1
PLANNING_AGENT_MODEL_API_KEY=
PLANNING_AGENT_MODEL_TIMEOUT=120
SKILL_LLM_TLS_VERIFY=false

DPA_AGENT_ID=edp_agent
DPA_AGENT_NAME=EDP Agent
DPA_MAX_ITERATIONS=30

va_workflow_result_node=GXZQAResponseNode

# Sandbox mode → jiuwenbox on docker network
SANDBOX_URL=http://jiuwenbox:8321
SKILL_TARGET_PATH=/tmp
