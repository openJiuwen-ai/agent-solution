# sandbox 实验环境变量（复制为同目录 .env 后按需修改）

ADAPTER_PORT=8900
ADAPTER_POLL_INTERVAL=5
ADAPTER_START_FROM=head

# 宿主机路径（Windows 示例，按本机调整）
HOST_OUTPUT_DIR=D:/jiuwenagent/AE-TEAM/agent-store/community/EvoAgentAdapter/deployment/sandbox-experiment/data
HOST_CONFIG_FILE=D:/jiuwenagent/AE-TEAM/agent-store/community/EvoAgentAdapter/deployment/sandbox-experiment/agent_adapter_config.yaml
HOST_LOG_ROOT=D:/jiuwenagent/AE-TEAM/agent-store/community/EDPAgent/deployment/logs
HOST_SKILLS_META=D:/jiuwenagent/AE-TEAM/agent-store/community/EvoAgentAdapter/deployment/sandbox-experiment/skills-meta

JIUWENBOX_IMAGE=jiuwenbox:latest
JIUWENBOX_HOST_PORT=8321
