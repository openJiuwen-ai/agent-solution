# ── EDPAgent 环境变量配置（本地 spring-boot:run / java -jar）──
#
# model / versatile 已迁移至 application.yml 的 edpa.agent.*，
# Spring Boot 原生支持 ${ENV_VAR:default} 占位符。
#
# 治理配置（planrule / actrule / scriptconfig）位于 engine/src/main/resources/governance/
# 场景配置位于 scenarios/<场景名>/（通过 EDP_AGENT_SCENARIO_HOME 切换）

# ── LLM 模型密钥（必填） ──
EDP_AGENT_MODEL_API_KEY=your-api-key-here

# ── LLM 模型配置（可选覆盖 application.yml 默认值） ──
EDP_AGENT_MODEL_PROVIDER=OpenAI
EDP_AGENT_MODEL_NAME=deepseek-v4-pro
EDP_AGENT_MODEL_BASE_URL=https://api.deepseek.com/v1

# ── Versatile / adapter（可选覆盖 application.yml 默认值） ──
EDP_AGENT_VERSATILE_URL=http://localhost:30001/v1/0/agent-manager/workflows/{workflow_id}/conversations/{conversation_id}
EDP_AGENT_VERSATILE_A2A_URL=http://localhost:8191/a2a

# ── 场景路径（可选，默认 ../scenarios/wealth-demo） ──
# EDP_AGENT_SCENARIO_HOME=../scenarios/hz-zhidaitong
EDP_AGENT_SCENARIO_HOME=../scenarios/wealth-demo

# ── 日志配置 ──
EDP_AGENT_LOG_LEVEL=INFO

# ── MCP 产品列表（call_mcp 脚本使用，可选）──
# MCP_MASTER_URL=http://...
# MCP_STANDBY_URL=http://...
# MCP_ACCESS_TOKEN=your-mcp-token
# MCP_APP_NAME=f-mlp
