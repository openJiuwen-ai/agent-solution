# ===== LLM =====
# provider 开关："OpenAI"（公网/开发，默认）| "CustomSSE"（私有部署）
EVO_LLM_PROVIDER=OpenAI
EVO_LLM_API_KEY=sk-xxx
EVO_LLM_BASE_URL=https://api.openai.com/v1
EVO_OPTIMIZER_MODEL=gpt-4o
# LLM 评估器模型；不填则与 EVO_OPTIMIZER_MODEL 相同
# EVO_EVALUATOR_MODEL=gpt-4o-mini
EVO_TARGET_MODEL=gpt-4o
# ===== 自定义 SSE provider 凭证（仅 EVO_LLM_PROVIDER=CustomSSE 时必填） =====
# 启用：把 EVO_LLM_PROVIDER 改 CustomSSE，并至少填写 token、userId、endpoint、context window。
# 注意：docker --env-file 不支持行内注释，每行行尾不要写 # 注释。
# EVO_CUSTOM_SSE_TOKEN=<TOKEN，走 Secret 注入，勿提交明文>
# EVO_CUSTOM_SSE_USER_ID=<固定 userId>
# EVO_CUSTOM_SSE_ENDPOINT=https://llm-gateway.example.com/v1/chat/completions
# EVO_CUSTOM_SSE_CONTEXT_WINDOW_TOKENS=32768
# EVO_CUSTOM_SSE_TIMEOUT=120.0
# EVO_CUSTOM_SSE_OUTPUT_RESERVE_TOKENS=2048
# EVO_CUSTOM_SSE_CHARS_PER_TOKEN=2.0
# EVO_CUSTOM_SSE_COMPLETION_SIGNAL=done

# ===== LLM 上下文预算（所有 Provider） =====
EVO_LLM_CONTEXT_WINDOW_TOKENS=32768
EVO_LLM_OUTPUT_RESERVE_TOKENS=2048
EVO_LLM_SAFETY_MARGIN_TOKENS=512
EVO_LLM_CHARS_PER_TOKEN=2.0
# JSON：按阶段覆盖输出预留 token
EVO_LLM_STAGE_OUTPUT_RESERVE_TOKENS={"evaluator":1200,"reflect":4096}

# ===== 远程通信（AdapterClient 使用） =====
EVO_REMOTE_TIMEOUT=300.0
EVO_REMOTE_PARALLEL=4

# ===== 优化超参 =====
EVO_DEFAULT_EPOCHS=3
EVO_DEFAULT_BATCH_SIZE=4
EVO_ACCUMULATION=2
EVO_EDIT_BUDGET=10
EVO_SCHEDULER_MODE=constant
EVO_USE_SLOW_UPDATE=true
EVO_USE_META_SKILL=true
EVO_PRESERVE_FRONTMATTER=true

# ===== Managed-doc（AgentRule.md 等） =====
# 必须至少比 Adapter 返回的 max_task_seconds 大 10 秒。
EVO_MANAGED_DOC_APPLY_DEADLINE=600
EVO_MANAGED_DOC_CANCEL_ROLLBACK_DEADLINE=900
# JSON：默认 preserving 会保护 frontmatter；无额外保护区段时保持空对象。
EVO_MANAGED_DOC_CONTENT_POLICIES={"agent_rule":"preserving"}
EVO_MANAGED_DOC_PROTECTED_SECTIONS={}

# ===== 路径 =====
EVO_WORKSPACE_ROOT=./workspace
EVOAGENT_CONTROL_DB_PATH=./workspace/evoagent-control.db
EVO_OUTPUT_ROOT=./workspace/outputs
EVO_ARTIFACT_DIR=./workspace/artifacts

# ===== 平台 API 配置（Wave 8） =====
# Adapter sidecar 地址（API 模式必填）
EVO_ADAPTER_URL=http://localhost:9090

# 数据集路径安全白名单（逗号分隔）
EVO_ALLOWED_DATA_ROOTS=/data/evo_agent,/tmp/evo_agent
