# EvoAgentAdapter 部署配置
# 使用方法：复制为 .env 并按需修改
#   cp .env.example .env && vim .env
#
# 启动：./start.sh --build   （首次启动需 --build 构建镜像）
# 停止：./stop.sh

# ===== 必填：主机路径（多 Agent 策略 A：公共父目录）=====
# 所有业务 Agent 的日志父目录（挂载到容器 /data/logs，只读）。
# 每个业务 Agent 的日志放在其子目录，如 /var/log/agents/edp_agent、.../hr_agent。
# agent_adapter_config.yaml 中 per-agent log_dir 写 /data/logs/{name} 对应此处的 {name} 子目录。
HOST_LOG_ROOT=/var/log/agents

# 所有业务 Agent 的 skills 父目录（挂载到容器 /data/skills，读写）。
# 每个业务 Agent 的 skills 放在其子目录，如 /opt/agents/skills/edp_agent。
# per-agent skills_dir 写 /data/skills/{name} 对应此处的 {name} 子目录。
HOST_SKILLS_ROOT=/opt/agents/skills

# 所有业务 Agent managed-doc 的公共父目录（挂载到容器 /data/agents，读写）。
# AgentRule.md 必须与业务 Agent 容器挂载同一份宿主机文件。
# 例如 YAML path=/data/agents/edp_agent/AgentRule.md 对应：
#   ${HOST_AGENTS_ROOT}/edp_agent/AgentRule.md
HOST_AGENTS_ROOT=/opt/agents/runtime

# Adapter 输出数据持久化目录（挂载到容器 /app/data，读写）
# 存储 offsets、output 归档等运行时数据
HOST_OUTPUT_DIR=/opt/agent-adapter/data

# Adapter 配置文件持久化路径（挂载到容器 /app/agent_adapter_config.yaml，读写）
# 热更新（CRUD /api/v1/config/agents）写入此文件，跨容器重建不丢失
# start.sh 首次启动时若该文件不存在，会从镜像内模板自动 seed；已存在则不覆盖
# docker-compose 部署时需在 up 前手动 cp 模板到此路径（start.sh 会自动 seed，compose 不会）
HOST_CONFIG_FILE=/opt/agent-adapter/agent_adapter_config.yaml

# ===== 可选：managed-doc Docker restart =====
# 默认关闭。设为 true 后 start.sh 才会挂载 Docker socket，使 restart_cmd 中的
# `docker restart <container>` 可用。Docker socket 具有宿主机 root 等价权限。
ADAPTER_ENABLE_DOCKER_RESTART=false
HOST_DOCKER_SOCKET=/var/run/docker.sock

# agent_adapter_config.yaml 的 extra_headers 可用 ${ADAPTER_AGENT_TOKEN} 引用。
# 生产环境请由 Secret 注入；不需要鉴权时留空。
ADAPTER_AGENT_TOKEN=

# ===== 可选：Adapter 服务配置 =====
# 日志轮询间隔（秒）
ADAPTER_POLL_INTERVAL=60

# 首次启动读取位置：tail（只读新日志） | head（从头读历史日志）
ADAPTER_START_FROM=tail

# 输出文件清理策略
ADAPTER_OUTPUT_RETENTION_DAYS=30
ADAPTER_OUTPUT_MAX_FILES=2000
ADAPTER_OUTPUT_MAX_FILE_SIZE=20MB

# 日志等级：DEBUG | INFO | WARNING | ERROR
ADAPTER_LOG_LEVEL=INFO

# ===== 可选：Agent 轨迹采集（基于 OTel）=====
# 轨迹获取模式：
#   log      —— 读归档日志（默认，零外部依赖）
#   standard —— 读 collector 侧的 PG + Kafka（需 collector 已部署且网络可达）
# 切 standard 时需同时设 ADAPTER_NETWORK（见下方说明）。
ADAPTER_TRACE_SOURCE=log

# 数据库类型（目前仅 postgres）
ADAPTER_DB_TYPE=postgres

# PostgreSQL 连接（standard 模式读 collector 落库的轨迹）
ADAPTER_PG_HOST=postgres
ADAPTER_PG_PORT=5432
ADAPTER_PG_DB=agent_adapter
ADAPTER_PG_USER=otel_user
ADAPTER_PG_PASSWORD=otel_password

# Kafka 消费（standard 模式从 collector 的 OTLP trace topic 消费）
ADAPTER_KAFKA_BROKERS=kafka:9092
ADAPTER_KAFKA_TOPIC=otlp_traces
ADAPTER_KAFKA_GROUP=agent-adapter

# GET /traces/{conv} 等根 span 的服务端短等待秒数（standard 模式；设计 §7: 5s 上报 + 余量）
ADAPTER_TRACE_WAIT_TIMEOUT=10.0

# ── 网络接入（仅 start.sh 拉起方式使用，compose 另见 docker-compose.yml 末尾注释）──
# 留空 = 默认 bridge 网络；standard 模式需设为 collector 所在网络（如 openjiuwen-net），
# 以解析 kafka / postgres 容器别名。compose 部署不读此项，改用 networks 块。
ADAPTER_NETWORK=
