# EDP Agent 独立 Docker 部署配置
#
# 使用方法：
#   cp deploy/.env.example deploy/.env
#   chmod 600 deploy/.env
#   vi deploy/.env
#
# 规则：KEY=value，等号两侧不要加空格，不要加引号。
# deploy/.env 含密钥且已被仓库根 .gitignore 忽略，禁止提交。

# ── 部署脚本控制项 ────────────────────────────────────────────
# 生产环境建议改成版本号或提交号标签，例如 edp-agent-java:0.1.0-20260714；
# 不建议长期使用 latest，因为它无法准确审计部署了哪个版本。
EDP_IMAGE=edp-agent-java:0.1.0
EDP_CONTAINER=edp-agent
EDP_HOST_PORT=8190

# 与 adapter 团队约定的、由双方脚本只创建/使用但永不删除的共享 bridge 网络。
AGENT_NETWORK=agent-net

# local：本脚本管理一个本机 Redis 容器；external：只连接外部 Redis，绝不管理它。
EDP_REDIS_DEPLOYMENT=local
EDP_REDIS_IMAGE=redis:7-alpine
EDP_REDIS_CONTAINER=edp-redis
EDP_REDIS_VOLUME=edp-redis-data

# ── 大模型：API Key 必填 ──────────────────────────────────────
EDP_AGENT_MODEL_PROVIDER=OpenAI
EDP_AGENT_MODEL_NAME=deepseek-v4-pro
EDP_AGENT_MODEL_BASE_URL=https://api.deepseek.com/v1
EDP_AGENT_MODEL_API_KEY=

# ── Redis ─────────────────────────────────────────────────────
# local 模式下 start.sh 会固定使用 single / edp-redis / 6379 / 空密码。
# external 模式下请把 HOST 改为容器内可访问的 DNS 或 IP；切勿填写 localhost。
EDPA_REDIS_MODE=single
EDPA_REDIS_HOST=edp-redis
EDPA_REDIS_PORT=6379
EDPA_REDIS_PASSWORD=
EDPA_REDIS_DB=0
EDPA_REDIS_CONNECT_TIMEOUT=5000
EDPA_REDIS_SOCKET_TIMEOUT=10000
EDPA_REDIS_CHECKPOINTER_TTL=60
EDPA_REDIS_KEY_PREFIX=edpa
EDPA_REDIS_TODO_TTL=3600
EDPA_REDIS_REFRESH_ON_READ=true

# ── adapter / Versatile ───────────────────────────────────────
# 同一 Docker 主机默认通过共享网络中的 alias 访问 adapter。
# 跨主机部署时改成 adapter 团队提供的、可路由的 DNS/LB 地址。
EDP_AGENT_VERSATILE_A2A_URL=http://adapter-versatile:8191/a2a
EDP_AGENT_VERSATILE_TIMEOUT=30s

# 当前应用启动校验仍要求 direct URL 是合法的 http(s) URL；A2A URL 非空时业务主链路
# 始终走上面的 adapter。此兼容值不要留空；若启用 REST 直连，必须改为真实 Versatile URL。
EDP_AGENT_VERSATILE_URL=http://adapter-versatile:8191/a2a

# ── MCP：默认显式置空，防止继承 JAR 内公网测试地址/token ─────
# 不调用 MCP 时空值不影响服务启动；启用 call_mcp 前必须填写受控的生产地址与凭据。
EDP_MCP_MASTER_URL=
EDP_MCP_STANDBY_URL=
EDP_MCP_ACCESS_TOKEN=
EDP_MCP_APP_NAME=

# ── 沙箱（Sandbox）──────────────────────────────────────────
# 默认关闭。启用沙箱需同时设置两个开关为 true，并配置沙箱服务地址。
#
# 第一层开关（治理装饰层）：
#   控制 AgentCoreSandboxClientFactory Bean 创建，启用熔断/重试/审计装饰。
#   false → Path 1（直接模式，无治理装饰）；true → Path 2（治理装饰模式）。
EDPA_SANDBOX_GOVERNED_ENABLED=false

# 第二层开关（EDP 沙箱功能）：
#   控制 SandboxInitHook / SandboxShutdownHook 注册、SysOperation 创建、
#   VersatileInterruptRail / McpInterruptRail 沙箱委派执行。
EDPA_SANDBOX_ENABLED=false

# 沙箱服务地址（JiuwenSwarm / jiuwenbox 服务）。
# 容器内部可路由的 DNS 或 IP，不要使用 localhost/127.0.0.1。
# 同一 Docker 主机时，沙箱服务容器应加入 agent-net 网络，使用容器名访问。
EDPA_SANDBOX_SERVICE_URL=http://127.0.0.1:8321

# 沙箱容器 ID 前缀，用于区分不同 EDP 实例的沙箱容器。
EDPA_SANDBOX_ID_PREFIX=edp

# 脚本执行超时（秒）。与治理装饰层 timeout-ms 取较短者生效。
EDPA_SANDBOX_EXEC_TIMEOUT=60

# 技能包在沙箱容器内的部署路径。沙箱创建后会自动部署此路径下的技能包。
EDPA_SANDBOX_SKILL_DEPLOY_PATH=/app/skills

# 启动时自动创建沙箱容器。true → 应用启动后立即创建并部署技能；
# false → 需在首次业务请求时按需创建（可能增加首次响应延迟）。
EDPA_SANDBOX_AUTO_CREATE=true

# 停止时的清理策略。delete → 停止时删除沙箱容器；retain → 保留容器。
EDPA_SANDBOX_ON_STOP=delete

# 沙箱失败时是否降级到本地执行（ProcessBuilder）。
# true → 沙箱不可用时自动降级，业务不中断但失去隔离保护；
# false → 沙箱不可用时直接报错，强制隔离语义。
EDPA_SANDBOX_FALLBACK_ON_FAILURE=true

# 不走沙箱的命令列表（逗号分隔）。这些命令始终在本地执行。
EDPA_SANDBOX_EXCLUDED_COMMANDS=whoami,hostname

# 容器隔离级别。SESSION → 每个会话独立沙箱容器（推荐，隔离性最强）；
# GLOBAL → 所有会话共享一个沙箱容器（资源开销更低）。
EDPA_SANDBOX_CONTAINER_SCOPE=SESSION

# 沙箱容器创建超时（秒）。超过此时间未创建成功则触发降级或报错。
EDPA_SANDBOX_CREATE_TIMEOUT=30
