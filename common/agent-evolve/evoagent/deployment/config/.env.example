# ============================================================
# EvoAgent 配置模板
# 复制为 .env 并填入实际值：
#   cp config/.env.example config/.env
# ============================================================

# Adapter sidecar 地址
EVO_ADAPTER_URL=http://124.71.234.237:8900

# ── LLM ──
EVO_LLM_PROVIDER=OpenAI
EVO_LLM_API_KEY=sk-xxxxxx
EVO_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVO_OPTIMIZER_MODEL=qwen3.7-max
EVO_TARGET_MODEL=qwen3.7-max

# ── LLM Provider 切换（自定义 SSE 模式）──
# 默认走 OpenAI 兼容模式（用上面 EVO_LLM_*）；自定义 SSE 模型端点设为 CustomSSE。
# 设为 CustomSSE 后，token、userId、endpoint、context window 四项必填（OpenAI 模式忽略）。
# 启用方法：删掉所需行行首的 #。注意每行行尾不要留 # 注释（docker --env-file
# 不支持行内注释，行尾 # 之后的内容会被当成值的一部分）。
#
# 私有部署 CustomSSE 鉴权 token（Secret 注入，勿硬编码）
# EVO_CUSTOM_SSE_TOKEN=<TOKEN>
# 私有部署分配的固定 userId
# EVO_CUSTOM_SSE_USER_ID=<固定 userId>
# 私有部署 chat/completions 流式端点（OpenAI 消息格式 + SSE）
# EVO_CUSTOM_SSE_ENDPOINT=https://llm-gateway.example.com/v1/chat/completions
# 模型上下文窗口（token），CustomSSE 模式必填；按现场模型规格填写
# EVO_CUSTOM_SSE_CONTEXT_WINDOW_TOKENS=32768
# 流式 read 超时（秒），默认 120；两个 chunk 之间最长间隔
# EVO_CUSTOM_SSE_TIMEOUT=120.0
# EVO_CUSTOM_SSE_OUTPUT_RESERVE_TOKENS=2048
# EVO_CUSTOM_SSE_CHARS_PER_TOKEN=2.0
# EVO_CUSTOM_SSE_COMPLETION_SIGNAL=done

# ── LLM 上下文预算（所有 Provider） ──────────────────────────
EVO_LLM_CONTEXT_WINDOW_TOKENS=32768
EVO_LLM_OUTPUT_RESERVE_TOKENS=2048
EVO_LLM_SAFETY_MARGIN_TOKENS=512
EVO_LLM_CHARS_PER_TOKEN=2.0
EVO_LLM_STAGE_OUTPUT_RESERVE_TOKENS={"evaluator":1200,"reflect":4096}

# ── 数据路径（逗号分隔） ──
EVO_ALLOWED_DATA_ROOTS=/tmp/evo_agent,/data/evo_agent,/home/evolution/evoagent-studio


# ── 远程通信（AdapterClient） ──────────────────────────────
EVO_REMOTE_TIMEOUT=300.0
EVO_REMOTE_MAX_RETRIES=2
EVO_REMOTE_PARALLEL=4

# ── 优化超参数 ─────────────────────────────────────────────
EVO_DEFAULT_EPOCHS=3
EVO_DEFAULT_BATCH_SIZE=4
EVO_ACCUMULATION=2
EVO_MINIBATCH_SIZE=8
EVO_EDIT_BUDGET=10
EVO_SCHEDULER_MODE=constant
EVO_UPDATE_MODE=patch
EVO_USE_SLOW_UPDATE=true
EVO_USE_META_SKILL=true
EVO_PRESERVE_FRONTMATTER=true
EVO_SCORE_THRESHOLD=0.5
EVO_PARALLELISM=4

# ── Managed-doc（AgentRule.md 等） ────────────────────────────
# 必须 >= Adapter managed-doc snapshot 返回的 max_task_seconds + 10。
EVO_MANAGED_DOC_APPLY_DEADLINE=600
EVO_MANAGED_DOC_CANCEL_ROLLBACK_DEADLINE=900
# JSON 对象；默认 preserving 会保护 Markdown frontmatter。
EVO_MANAGED_DOC_CONTENT_POLICIES={"agent_rule":"preserving"}
# 可按 doc kind 配置必须原样保留的 marker 区段；无则保持空对象。
EVO_MANAGED_DOC_PROTECTED_SECTIONS={}

# ── 路径 ─────────────────────────────────────────────────────
# 容器内路径，通常无需修改
# workspace 通过 docker -v 挂载到宿主机
EVO_WORKSPACE_ROOT=./workspace
EVOAGENT_CONTROL_DB_PATH=./workspace/evoagent-control.db
EVO_OUTPUT_ROOT=./workspace/outputs
EVO_ARTIFACT_DIR=./workspace/artifacts
